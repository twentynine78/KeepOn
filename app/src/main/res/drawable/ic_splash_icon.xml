<?xml version="1.0" encoding="utf-8"?>
<!-- Splash icon, pre-Android-12 variant (core-splashscreen compat). The compat library mis-scales an
     <adaptive-icon> foreground so the mark overflows the background circle on API <31. Instead of
     relying on adaptive masking, the circle is baked in here: a solid-colour oval
     (@color/splash_icon_background — the brand-blue fallback at these API levels) with the base
     foreground drawn over it at its natural safe-zone size. The native adaptive variant used on
     API 31+ lives in drawable-v31/ic_splash_icon.xml. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/splash_icon_background" />
        </shape>
    </item>
    <item android:drawable="@drawable/ic_launcher_foreground" />
</layer-list>
