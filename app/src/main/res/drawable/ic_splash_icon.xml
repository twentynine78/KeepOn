<?xml version="1.0" encoding="utf-8"?>
<!-- Splash icon: the base launcher foreground (no inversion) on a circular background filled with
     the Material You primary (@color/splash_icon_background — dynamic on API 31+, brand-blue
     fallback below). Modelled on ic_launcher.xml so the splash shows the same mark as the launcher,
     just with a theme-driven circle instead of the static launcher backdrop. The platform splash
     detects the solid-colour adaptive background and draws it as the icon's circle, which is more
     reliable across OEMs than windowSplashScreenIconBackgroundColor. -->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/splash_icon_background"/>
    <foreground android:drawable="@drawable/ic_launcher_foreground"/>
</adaptive-icon>
